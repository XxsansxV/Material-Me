{
    "label" : "lock",
    "action" : "loginctl lock-session",
    "text" : "Lock",
    "keybind" : "l"
}
{
    "label" : "saysmt",
    "action" : "bash ~/.config/fish/GreetMeInBash.sh notify",
    "text" : "Say something",
    "keybind" : "h"
}
{
    "label" : "logout",
    "action" : "hyprctl dispatch 'hl.dsp.exit()'",
    "text" : "Logout",
    "keybind" : "e"
}
{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "text" : "Shutdown",
    "keybind" : "s"
}
{
    "label" : "sleep",
    "action" : "systemctl suspend",
    "text" : "Sleep",
    "keybind" : "u"
}
{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "Reboot",
    "keybind" : "r"
}
