{
    "label" : "lock",
    "action" : "loginctl lock-session",
    "text" : "[L]ock",
    "keybind" : "l"
}
{
    "label" : "saysmt",
    "action" : "bash ~/.config/fish/GreetMeInBash.sh notify",
    "text" : "say so[M]ething",
    "keybind" : "m"
}
{
    "label" : "logout",
    "action" : "hyprctl dispatch 'hl.dsp.exit()'",
    "text" : "l[O]gout",
    "keybind" : "o"
}
{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "text" : "[S]hutdown",
    "keybind" : "s"
}
{
    "label" : "sleep",
    "action" : "systemctl suspend",
    "text" : "sl[E]ep",
    "keybind" : "e"
}
{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "[R]eboot",
    "keybind" : "r"
}
